{
  "annotations": { "list": [] },
  "editable": true,
  "schemaVersion": 38,
  "tags": ["edulms", "sre"],
  "title": "EduLMS SRE — Overview",
  "timezone": "browser",
  "time": { "from": "now-30m", "to": "now" },
  "refresh": "10s",
  "panels": [
    {
      "type": "timeseries",
      "title": "Request rate (req/s) — payment",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (status) (rate(payment_requests_total[1m]))",
          "legendFormat": "status={{status}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Error rate (%) — payment",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "100 * sum(rate(payment_requests_total{status=~\"5..\"}[5m])) / clamp_min(sum(rate(payment_requests_total[5m])),0.001)",
          "legendFormat": "5xx %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Latency p95 (s) — payment",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(payment_request_latency_seconds_bucket[5m])))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(payment_request_latency_seconds_bucket[5m])))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Profiles count",
      "gridPos": { "x": 12, "y": 8, "w": 6, "h": 4 },
      "targets": [{ "expr": "user_profile_count" }]
    },
    {
      "type": "stat",
      "title": "In-flight (payment)",
      "gridPos": { "x": 18, "y": 8, "w": 6, "h": 4 },
      "targets": [{ "expr": "payment_inflight_requests" }]
    },
    {
      "type": "timeseries",
      "title": "Up status — every service",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 4 },
      "targets": [
        { "expr": "up", "legendFormat": "{{job}} / {{instance}}" }
      ]
    }
  ]
}
